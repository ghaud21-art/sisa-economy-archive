# Supabase (프로젝트 설정 > API 에서 확인)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 아래 값들은 배치 스크립트(scripts/generate-digest.ts)와 GitHub Actions에서만 사용합니다.
# 절대 NEXT_PUBLIC_ 접두사를 붙이지 마세요 (브라우저에 노출됨).
SUPABASE_SERVICE_ROLE_KEY=

# Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# 네이버 개발자센터 (https://developers.naver.com/apps) - 검색 API 사용 신청
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
